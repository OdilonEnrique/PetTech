generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Pessoa {
  id          Int          @id @default(autoincrement())
  nome        String
  comentarios Comentario[]
}

model Animal {
  id                Int       @id @default(autoincrement())
  fotoUrl           String?
  nome              String
  especie           String
  raca              String?
  faixaEtaria       FaixaEtaria
  alimentacao       String
  higiene           String
  primeirosSocorros String
  posts             Post[]
}

model Post {
  id          Int          @id @default(autoincrement())
  animalId    Int
  titulo      String
  conteudo    String
  fotoUrl     String?
  likes       Int          @default(0)
  createdAt   DateTime     @default(now())

  animal      Animal       @relation(fields: [animalId], references: [id])
  comentarios Comentario[]
}

model Comentario {
  id        Int      @id @default(autoincrement())
  pessoaId  Int
  postId    Int
  texto      String
  createdAt DateTime @default(now())

  pessoa    Pessoa   @relation(fields: [pessoaId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
}

enum FaixaEtaria {
  FILHOTE
  ADULTO
  IDOSO
}